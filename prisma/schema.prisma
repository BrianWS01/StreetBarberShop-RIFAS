generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
}

model raffle {
  id             String        @id
  title          String
  prize          String
  pricePerTicket Decimal       @db.Decimal(10, 2)
  totalTickets   Int
  status         raffle_status @default(DRAFT)
  winnerNumber   Int?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime
  ticket         ticket[]
}

model ticket {
  id            String        @id
  number        Int
  status        ticket_status @default(AVAILABLE)
  raffleId      String
  userId        String?
  transactionId String?
  reservedAt    DateTime?
  paidAt        DateTime?
  raffle        raffle        @relation(fields: [raffleId], references: [id], onDelete: Cascade, map: "Ticket_raffleId_fkey")
  transaction   transaction?  @relation(fields: [transactionId], references: [id], map: "Ticket_transactionId_fkey")
  user          user?         @relation(fields: [userId], references: [id], map: "Ticket_userId_fkey")

  @@unique([raffleId, number], map: "Ticket_raffleId_number_key")
  @@index([transactionId], map: "Ticket_transactionId_fkey")
  @@index([userId], map: "Ticket_userId_fkey")
}

model transaction {
  id           String             @id
  externalId   String?            @unique(map: "Transaction_externalId_key")
  amount       Decimal            @db.Decimal(10, 2)
  status       transaction_status @default(PENDING)
  qrCode       String?            @db.Text
  qrCodeBase64 String?            @db.Text
  createdAt    DateTime           @default(now())
  updatedAt    DateTime
  ticket       ticket[]
}

model user {
  id        String    @id
  name      String
  phone     String    @unique(map: "User_phone_key")
  role      user_role @default(USER)
  createdAt DateTime  @default(now())
  updatedAt DateTime
  ticket    ticket[]
}

enum ticket_status {
  AVAILABLE
  RESERVED
  PAID
}

enum transaction_status {
  PENDING
  PAID
  FAILED
  EXPIRED
}

enum user_role {
  USER
  ADMIN
}

enum raffle_status {
  DRAFT
  ACTIVE
  FINISHED
}
